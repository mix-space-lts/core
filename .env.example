PORT=2333
TZ=${TZ:-Asia/Shanghai}
ALLOWED_ORIGINS=localhost:*

DB_CONNECTION_STRING=mongodb://mongo:27017/mx-space

REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_CONNECTION_STRING=""
# REDIS_PASSWORD=""

JWT_SECRET=YOUR_SUPER_SECURED_JWT_SECRET_STRING
# JWT_EXPIRE=14 # in days

# Encryption (optional)
# ENCRYPT_KEY must be length 64 if ENCRYPT_ENABLE=true
ENCRYPT_ENABLE=false
# ENCRYPT_KEY=changemechangemechangemechangemechangemechangemechangemechangeme
# ENCRYPT_ALGORITHM=""

DISABLE_CACHE=false

DEBUG=false
DEBUG_MEMORY_DUMP=false

