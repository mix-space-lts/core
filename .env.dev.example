# ============================================
# Mix Space LTS - 开发环境变量模板
# 由 scripts/dev-up.sh 复制为 .env 使用
# ============================================

NODE_ENV=dev

PORT=2333
ALLOWED_ORIGINS=localhost:*

MONGO_CONNECTION=mongodb://localhost:27017/mx-space
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=dev-jwt-secret-do-not-use-in-production

CDN_CACHE_HEADER=false
DISABLE_CACHE=true
THROTTLE_TTL=60
THROTTLE_LIMIT=200
